#!/usr/bin/env bash
set -euo pipefail

# --- USER CONFIGURATION ---
DISK="/dev/vda" # Correct for the VM
HOSTNAME="nixos-server"
GIT_REPO_URL="https://github.com/pervezfunctor/nixos-remote.git"
FLAKE_REPO="https://github.com/pervezfunctor/nixos-remote"
MOUNTPOINT="/mnt"
FLAKE_OUTPUT="nixos-remote-unlock"
SWAP_SIZE="4G"

# --- SCRIPT LOGIC ---

echo "------------------------------------------------------------------"
echo "!! WARNING: This script will ERASE ALL DATA on ${DISK}."
echo "You have 10 seconds to press Ctrl+C to cancel."
echo "------------------------------------------------------------------"
sleep 10

if [ "$EUID" -ne 0 ]; then
  echo "This script must be run as root."
  exit 1
fi

if ! [ -b "$DISK" ]; then
  echo "Disk ${DISK} not found."
  exit 1
fi

echo "--> Partitioning disk ${DISK}..."
sgdisk --zap-all "${DISK}"
sgdisk -n 1:0:+1G -t 1:ef00 -c 1:efiboot "${DISK}"
sgdisk -n 2:0:0 -t 2:8309 -c 2:cryptroot "${DISK}" # GPT partition label
sync

echo "--> Waiting for partitions to appear..."
# This is a more robust way to wait. It tells the kernel to re-read the
# partition table and then waits for the specific device link to be created.
partprobe "${DISK}"
sleep 2 # Give udev a moment to create the links

# --- MODIFICATION ---
# Use the partition labels directly. This is much more reliable than device names.
EFI_PART="/dev/disk/by-partlabel/efiboot"
LUKS_PART="/dev/disk/by-partlabel/cryptroot"

# Wait until the LUKS partition actually exists before trying to use it.
while [ ! -e "${LUKS_PART}" ]; do
  echo "Waiting for ${LUKS_PART} to be created..."
  sleep 1
done

echo "--> Setting up LUKS encryption on ${LUKS_PART}..."
cryptsetup luksFormat --type luks2 -q "${LUKS_PART}"
cryptsetup open "${LUKS_PART}" cryptroot

echo "--> Setting up LVM on top of LUKS..."
pvcreate /dev/mapper/cryptroot
vgcreate nixos /dev/mapper/cryptroot
lvcreate -L "${SWAP_SIZE}" -n swap nixos
lvcreate -l '100%FREE' -n root nixos

echo "--> Formatting filesystems with labels..."
mkfs.vfat -n BOOT "${EFI_PART}"
mkfs.ext4 -L root /dev/mapper/nixos-root
mkswap -L swap /dev/mapper/nixos-swap

echo "--> Mounting filesystems..."
mount /dev/disk/by-label/root ${MOUNTPOINT:-/mnt}
mkdir -p ${MOUNTPOINT:-/mnt}/boot
mount /dev/disk/by-label/BOOT ${MOUNTPOINT:-/mnt}/boot
swapon /dev/disk/by-label/swap

echo "--> Cloning NixOS configuration from ${GIT_REPO_URL}..."
git clone "$FLAKE_REPO" "$MOUNTPOINT/etc/nixos"

sed -i "s/nixos-server/${HOSTNAME}/" ${MOUNTPOINT:-/mnt}/etc/nixos/configuration.nix

echo "--> Pre-generating SSH host key for the new system..."
mkdir -p /mnt/etc/ssh
# Generate just the ed25519 key, as it's what our config needs.
# -N "" specifies an empty passphrase.
ssh-keygen -t ed25519 -f /mnt/etc/ssh/ssh_host_ed25519_key -N ""
# Ensure correct permissions for the key
chmod 600 /mnt/etc/ssh/ssh_host_ed25519_key
echo "--> SSH host key generated."

echo "--> Installing NixOS..."
nixos-install --flake "${MOUNTPOINT:-/mnt}/etc/nixos#${FLAKE_OUTPUT}" --no-root-passwd

echo "--> Installation complete! Unmounting filesystems..."
umount -R ${MOUNTPOINT:-/mnt}

echo "You can now reboot. Unlock with: ssh root@<ip_address>"
